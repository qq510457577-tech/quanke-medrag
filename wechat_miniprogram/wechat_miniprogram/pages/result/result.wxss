/* pages/result/result.wxss */

.result-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 20rpx;
}

.result-icon {
  font-size: 60rpx;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a5276;
}

/* 章节标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin: 40rpx 0 20rpx;
}

/* 诊断卡片 */
.diagnosis-list {
  margin-bottom: 20rpx;
}

.diagnosis-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #ecf0f1;
}

.diagnosis-card.primary {
  border-color: #e74c3c;
  background: linear-gradient(135deg, #fff5f5, #ffffff);
}

.diagnosis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.diagnosis-name {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #2c3e50;
}

.rank-icon {
  width: 48rpx;
  height: 48rpx;
  background: #1a5276;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.confidence {
  font-size: 40rpx;
  font-weight: 700;
}

.confidence.high { color: #e74c3c; }
.confidence.medium { color: #f39c12; }
.confidence.low { color: #3498db; }

.diagnosis-reason {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.reason-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a5276;
}

.reason-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
  margin-top: 8rpx;
}

.diagnosis-category {
  margin-top: 16rpx;
}

.category-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #e8f4f8;
  color: #1a5276;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 临床思维链 */
.reasoning-box {
  padding: 30rpx;
}

.reasoning-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 检查项目 */
.exam-section {
  margin-bottom: 24rpx;
}

.exam-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.exam-icon {
  font-size: 32rpx;
}

.exam-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
}

.exam-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.exam-item {
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2c3e50;
}

.exam-item.optional {
  background: #fffbf0;
  color: #f39c12;
}

/* 风险分层 */
.risk-section {
  border-left: 8rpx solid #f39c12;
}

.risk-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.risk-icon {
  font-size: 36rpx;
}

.risk-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
}

.risk-content {
  font-size: 28rpx;
  color: #f39c12;
  padding: 16rpx 20rpx;
  background: #fffbf0;
  border-radius: 12rpx;
}

.risk-content.high {
  color: #e74c3c;
  background: #fff5f5;
}

/* 免责声明 */
.disclaimer {
  display: flex;
  gap: 16rpx;
  background: #f8f9fa;
  border: 2rpx solid #ecf0f1;
}

.disclaimer-icon {
  font-size: 36rpx;
}

.disclaimer-content {
  flex: 1;
}

.disclaimer-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #7f8c8d;
  margin-bottom: 8rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #95a5a6;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.btn-secondary, .btn-primary {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
}

.btn-secondary {
  background: #f8f9fa;
  color: #1a5276;
  border: 2rpx solid #1a5276;
}

.btn-primary {
  background: linear-gradient(135deg, #1a5276, #2874a6);
  color: #ffffff;
}
