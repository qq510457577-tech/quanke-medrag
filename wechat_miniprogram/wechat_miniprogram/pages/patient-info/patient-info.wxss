/* pages/patient-info/patient-info.wxss */

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a5276;
  margin-bottom: 40rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.label.required::after {
  content: ' *';
  color: #e74c3c;
}

.input-wrapper {
  display: flex;
  align-items: center;
}

.input-wrapper .input-field {
  flex: 1;
}

.unit {
  margin-left: 20rpx;
  color: #7f8c8d;
  font-size: 30rpx;
}

/* 性别选择器 */
.gender-selector {
  display: flex;
  gap: 30rpx;
}

.gender-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f8f9fa;
  border: 4rpx solid #ecf0f1;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.gender-btn .icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.gender-btn text:last-child {
  font-size: 28rpx;
  color: #7f8c8d;
}

.gender-btn.active {
  border-color: #1a5276;
  background: #e8f4f8;
}

.gender-btn.active text:last-child {
  color: #1a5276;
  font-weight: 600;
}

/* 文本域 */
.textarea-field {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border: 2rpx solid #ecf0f1;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.3s;
}

.textarea-field:focus {
  border-color: #1a5276;
  background: #ffffff;
}

/* 按钮 */
.btn-primary {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  border-radius: 50rpx;
  margin-top: 40rpx;
}

.back-btn {
  text-align: center;
  padding: 30rpx;
  margin-top: 20rpx;
}

.back-btn text {
  color: #7f8c8d;
  font-size: 28rpx;
}
