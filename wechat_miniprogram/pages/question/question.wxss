/* pages/question/question.wxss */

.question-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a5276 0%, #2874a6 50%, #f5f6fa 50%);
  display: flex;
  flex-direction: column;
}

/* 进度条 */
.progress-bar {
  padding: 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #2c3e50;
}

.round-text {
  font-size: 24rpx;
  color: #1a5276;
  font-weight: 600;
}

.progress-track {
  height: 8rpx;
  background: #ecf0f1;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #27ae60, #2ecc71);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 卡片容器 */
.card-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.card-wrapper {
  width: 100%;
  transition: transform 0.3s ease, rotate 0.3s ease;
}

/* 问题卡片 */
.question-card-content {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.question-target {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #e8f4f8;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #1a5276;
}

.target-icon {
  font-size: 28rpx;
}

.question-type {
  font-size: 24rpx;
  color: #7f8c8d;
  padding: 8rpx 16rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

.question-body {
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1.5;
  display: block;
}

.question-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background: #fffbf0;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #f39c12;
}

/* 选项区域 */
.answer-section {
  margin-bottom: 30rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.options-list.multi {
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.option-btn {
  padding: 24rpx 30rpx;
  background: #f8f9fa;
  border: 3rpx solid #ecf0f1;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #2c3e50;
  text-align: center;
  transition: all 0.3s;
}

.option-btn.selected {
  border-color: #1a5276;
  background: #e8f4f8;
  color: #1a5276;
  font-weight: 600;
}

.option-btn .check-icon {
  margin-right: 10rpx;
  color: #1a5276;
  font-weight: bold;
}

/* 是/否按钮 */
.yesno-list {
  display: flex;
  gap: 20rpx;
}

.yesno-btn {
  flex: 1;
  padding: 30rpx;
  border: 3rpx solid #ecf0f1;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
  transition: all 0.3s;
}

.yesno-btn.yes.selected {
  border-color: #27ae60;
  background: #e8f8f0;
  color: #27ae60;
}

.yesno-btn.no.selected {
  border-color: #e74c3c;
  background: #fee;
  color: #e74c3c;
}

/* 滑动提示 */
.swipe-hint {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #ecf0f1;
}

.swipe-hint text {
  font-size: 24rpx;
  color: #bdc3c7;
}

/* 底部操作 */
.bottom-actions {
  padding: 30rpx 40rpx;
  background: #ffffff;
}

.action-btns {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.action-btn.prev {
  background: #f8f9fa;
  color: #7f8c8d;
  border: 2rpx solid #ecf0f1;
}

.action-btn.next {
  background: linear-gradient(135deg, #1a5276, #2874a6);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(26, 82, 118, 0.3);
}

.action-btn.next.disabled {
  background: #bdc3c7;
  box-shadow: none;
}

/* 加载动画 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-box {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #1a5276;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-box text {
  margin-top: 30rpx;
  font-size: 30rpx;
  color: #2c3e50;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
